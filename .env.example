# Same Postgres as the sibling Hano scraper (docker compose in ../Hano).
HANO_DATABASE_URL=postgresql+psycopg://hano:hano@localhost:5432/hano

# Optional: how many Arbeitsagentur pages per search query (default 2).
HANOU_ONLINE_MAX_PAGES=3

# Max ranked jobs to tailor / show on dashboard.
HANOU_TOP_N=100

# Hard region filter for recommendations.
HANOU_REGION=Niedersachsen

# Max rows to pull from Hano var/*.jsonl when Postgres is unavailable.
HANOU_JSONL_LIMIT=5000

# Dashboard / serve
HANOU_SERVE_HOST=127.0.0.1
HANOU_SERVE_PORT=8765

# Drop postings older than N days (0 = disable).
HANOU_MAX_AGE_DAYS=90
# Verify job URLs are still live before ranking.
HANOU_VERIFY_URLS=true
# Skip stale Hano JSONL Arbeitsagentur dumps.
HANOU_SKIP_STALE_JSONL=true
